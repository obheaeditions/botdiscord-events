<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Détails et Supervision - <%= event.title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            discord: '#5865F2',
            discordDark: '#36393f',
            discordBackground: '#2f3136'
          }
        }
      }
    }
  </script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
    body {
      font-family: 'Outfit', sans-serif;
    }
  </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col selection:bg-discord selection:text-white">

  <!-- Header -->
  <header class="border-b border-slate-800 bg-slate-900/50 backdrop-blur-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <a href="/" class="bg-discord p-2 rounded-xl text-white shadow-lg shadow-discord/30">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </a>
        <span class="text-xl font-bold tracking-tight bg-gradient-to-r from-white via-slate-200 to-discord bg-clip-text text-transparent">EventBot Portal</span>
      </div>
      <div class="flex items-center space-x-4">
        <a href="/" class="text-slate-400 hover:text-white transition duration-200 text-sm font-semibold flex items-center">
          <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Retour au Tableau
        </a>
        <form action="/logout" method="POST" class="inline">
          <button type="submit" class="inline-flex items-center px-3 py-2 rounded-xl border border-slate-800 bg-slate-900/50 hover:bg-slate-800 text-slate-400 hover:text-white font-medium transition duration-200 text-sm">
            Déconnexion
          </button>
        </form>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <div class="flex items-center space-x-3 mb-2">
          <span class="px-3 py-1 rounded-full text-xs font-semibold bg-discord/10 text-discord border border-discord/20"><%= event.type %></span>
          <% if (event.is_blocked === 1) { %>
            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-rose-500/10 text-rose-500 border border-rose-500/20">🔒 Inscriptions Bloquées</span>
          <% } %>
          <span class="text-sm text-slate-500">
            <% if (event.end_date && event.end_date !== event.start_date) { %>
              <%= 'Du ' + event.start_date + ' à ' + event.start_time + ' au ' + event.end_date + (event.end_time ? ' à ' + event.end_time : '') %>
            <% } else { %>
              <%= 'Le ' + event.start_date + (event.end_time && event.end_time !== event.start_time ? ' de ' + event.start_time + ' à ' + event.end_time : ' à ' + event.start_time) %>
            <% } %>
          </span>
        </div>
        <h1 class="text-3xl font-extrabold tracking-tight text-white"><%= event.title %></h1>
      </div>
      
      <!-- Actions d'Administration -->
      <div class="flex flex-wrap gap-3 items-center">
        <!-- Bloquer/Débloquer -->
        <form action="/events/<%= event.id %>/toggle-block" method="POST" class="inline">
          <% if (event.is_blocked === 1) { %>
            <button type="submit" class="inline-flex items-center px-4 py-2 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition duration-200 text-sm">
              🔓 Débloquer Inscriptions
            </button>
          <% } else { %>
            <button type="submit" class="inline-flex items-center px-4 py-2 rounded-xl bg-amber-600 hover:bg-amber-500 text-white font-medium transition duration-200 text-sm shadow-lg shadow-amber-600/20">
              🔒 Bloquer Inscriptions
            </button>
          <% } %>
        </form>

        <!-- Publier la Composition -->
        <form action="/events/<%= event.id %>/publish-composition" method="POST" class="inline">
          <button type="submit" class="inline-flex items-center px-4 py-2 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-medium transition duration-200 text-sm shadow-lg shadow-violet-600/20">
            📢 Publier la Composition
          </button>
        </form>

        <!-- Republier / Synchroniser -->
        <form action="/events/<%= event.id %>/republish" method="POST" class="inline">
          <button type="submit" class="inline-flex items-center px-4 py-2 rounded-xl bg-discord hover:bg-discord/90 text-white font-medium transition duration-200 text-sm shadow-lg shadow-discord/20">
            🔄 Synchroniser Discord
          </button>
        </form>

        <!-- Supprimer -->
        <form action="/events/<%= event.id %>/delete" method="POST" onsubmit="return confirm('Voulez-vous vraiment supprimer cet événement et retirer tous ses messages Discord ? Cette action est irréversible.');" class="inline">
          <button type="submit" class="inline-flex items-center px-4 py-2 rounded-xl bg-rose-600 hover:bg-rose-500 text-white font-medium transition duration-200 text-sm shadow-lg shadow-rose-600/20">
            🗑️ Supprimer l'Événement
          </button>
        </form>
      </div>
    </div>

    <!-- Cards Counters Grid -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
      <div class="bg-emerald-950/20 border border-emerald-900/30 rounded-2xl p-5 text-center">
        <span class="text-emerald-400 font-bold block text-3xl mb-1"><%= counts.inscrit %></span>
        <span class="text-slate-400 text-xs font-medium uppercase tracking-wider">Inscrits</span>
      </div>
      <div class="bg-amber-950/20 border border-amber-900/30 rounded-2xl p-5 text-center">
        <span class="text-amber-400 font-bold block text-3xl mb-1"><%= counts.interesse %></span>
        <span class="text-slate-400 text-xs font-medium uppercase tracking-wider">Intéressés</span>
      </div>
      <div class="bg-orange-950/20 border border-orange-900/30 rounded-2xl p-5 text-center">
        <span class="text-orange-400 font-bold block text-3xl mb-1"><%= counts.en_attente %></span>
        <span class="text-slate-400 text-xs font-medium uppercase tracking-wider">En attente</span>
      </div>
      <div class="bg-rose-950/20 border border-rose-900/30 rounded-2xl p-5 text-center">
        <span class="text-rose-400 font-bold block text-3xl mb-1"><%= counts.pas_interesse %></span>
        <span class="text-slate-400 text-xs font-medium uppercase tracking-wider">Pas Intéressés</span>
      </div>
      <div class="bg-blue-950/20 border border-blue-900/30 rounded-2xl p-5 text-center">
        <span class="text-blue-400 font-bold block text-3xl mb-1"><%= counts.desinscrit %></span>
        <span class="text-slate-400 text-xs font-medium uppercase tracking-wider">Désinscrits</span>
      </div>
    </div>

    <!-- Two equal columns layout (1/2 and 1/2) on lg screens -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- Left side: Details, Files, Links -->
      <div class="space-y-6">
        <div class="bg-slate-900/30 border border-slate-800 p-6 rounded-3xl backdrop-blur-sm">
          <div class="flex justify-between items-center mb-6 border-b border-slate-850 pb-4">
            <h3 class="text-xl font-bold text-white flex items-center">
              <svg class="w-6 h-6 mr-2 text-discord" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Détails de l'Événement
            </h3>
            <a href="/events/<%= event.id %>/edit" class="px-3.5 py-1.5 rounded-xl bg-slate-850 hover:bg-slate-800 text-slate-200 font-semibold transition duration-200 text-xs border border-slate-800 flex items-center gap-1.5 shadow-sm">
              ✏️ Modifier l'Événement
            </a>
          </div>

          <div class="space-y-4">
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Durée Estimée</span>
              <span class="text-slate-200 font-semibold text-sm"><%= event.duration %></span>
            </div>
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Description Courte</span>
              <div class="text-slate-350 whitespace-pre-wrap text-sm leading-relaxed bg-slate-950/20 p-3.5 rounded-xl border border-slate-900"><%= event.desc_short %></div>
            </div>
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Détails & Organisation</span>
              <div class="text-slate-350 whitespace-pre-wrap text-sm leading-relaxed bg-slate-950/20 p-3.5 rounded-xl border border-slate-900"><%= event.desc_org %></div>
            </div>
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Salons Discord de publication</span>
              <div class="text-xs font-mono text-slate-400 bg-slate-950/40 p-3 rounded-xl border border-slate-900 overflow-x-auto"><%= JSON.parse(event.channels).join(', ') %></div>
            </div>
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-1">Rôles Discord Requis</span>
              <% const rList = JSON.parse(event.roles); %>
              <% if (rList.length === 0) { %>
                <span class="text-emerald-400 font-semibold text-xs bg-emerald-950/20 border border-emerald-900/30 px-3 py-1 rounded-xl inline-block mt-1">🔓 Ouvert à tous</span>
              <% } else { %>
                <div class="text-xs font-mono text-slate-400 bg-slate-950/40 p-3 rounded-xl border border-slate-900 overflow-x-auto mt-1"><%= rList.join(', ') %></div>
              <% } %>
            </div>
          </div>

          <!-- Files and links nested beautifully -->
          <div class="space-y-4 pt-6 border-t border-slate-850 mt-6">
            <!-- Images -->
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-2">Illustrations</span>
              <% const imgList = JSON.parse(event.images); %>
              <% if (imgList.length === 0) { %>
                <span class="text-slate-600 text-xs italic block bg-slate-950/20 p-3 rounded-xl border border-slate-900">Aucune image</span>
              <% } else { %>
                <div class="grid grid-cols-2 gap-2">
                  <% imgList.forEach(function(img) { %>
                    <a href="<%= img %>" target="_blank" class="block border border-slate-800 rounded-xl overflow-hidden hover:border-discord transition">
                      <img src="<%= img %>" class="object-cover h-20 w-full" alt="Illustration">
                    </a>
                  <% }); %>
                </div>
              <% } %>
            </div>

            <!-- Documents -->
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-2">Documents Joints</span>
              <% const docList = JSON.parse(event.documents); %>
              <% if (docList.length === 0) { %>
                <span class="text-slate-600 text-xs italic block bg-slate-950/20 p-3 rounded-xl border border-slate-900">Aucun document</span>
              <% } else { %>
                <ul class="space-y-1.5">
                  <% docList.forEach(function(doc) { %>
                    <li>
                      <a href="<%= doc %>" target="_blank" class="inline-flex items-center text-xs font-semibold text-discord hover:text-white transition duration-200">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        <%= doc.split('/').pop() %>
                      </a>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </div>

            <!-- Links -->
            <div>
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider block mb-2">Liens Externes</span>
              <% const linkList = JSON.parse(event.links); %>
              <% if (linkList.length === 0) { %>
                <span class="text-slate-600 text-xs italic block bg-slate-950/20 p-3 rounded-xl border border-slate-900">Aucun lien</span>
              <% } else { %>
                <ul class="space-y-1.5">
                  <% linkList.forEach(function(link) { %>
                    <li>
                      <a href="<%= link %>" target="_blank" class="inline-flex items-center text-xs font-semibold text-slate-400 hover:text-white transition duration-200 truncate max-w-full">
                        <svg class="w-4 h-4 mr-1 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                        </svg>
                        <%= link %>
                      </a>
                    </li>
                  <% }); %>
                </ul>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Registrations and waitlist table -->
      <div class="space-y-6">
        <div class="bg-slate-900/30 border border-slate-800 rounded-3xl overflow-hidden backdrop-blur-sm">
          <div class="px-6 py-5 border-b border-slate-800 flex justify-between items-center bg-slate-900/50">
            <h3 class="font-bold text-white text-lg flex items-center">
              <svg class="w-5 h-5 mr-2 text-discord" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
              Liste des Inscrits
            </h3>
            <span class="text-xs text-slate-500 font-mono"><%= registrations.length %> réponse(s)</span>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
              <thead class="text-xs uppercase bg-slate-950 text-slate-400 font-semibold tracking-wider">
                <tr>
                  <th scope="col" class="px-6 py-4">Pseudo Discord</th>
                  <th scope="col" class="px-6 py-4">User ID (Snowflake)</th>
                  <th scope="col" class="px-6 py-4">Statut</th>
                  <th scope="col" class="px-6 py-4">Date de réponse</th>
                  <th scope="col" class="px-6 py-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-850">
                <% if (registrations.length === 0) { %>
                  <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-slate-600 italic">
                      Aucune inscription enregistrée pour le moment.
                    </td>
                  </tr>
                <% } else { %>
                  <% registrations.forEach(function(reg) { %>
                    <tr class="hover:bg-slate-900/40 transition">
                      <td class="px-6 py-4 font-semibold text-slate-200">
                        <%= reg.username %>
                      </td>
                      <td class="px-6 py-4 text-xs font-mono text-slate-500">
                        <%= reg.user_id %>
                      </td>
                      <td class="px-6 py-4">
                        <% if (reg.status === 'inscrit') { %>
                          <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-950/40 text-emerald-400 border border-emerald-900/30">Inscrit</span>
                        <% } else if (reg.status === 'interesse') { %>
                          <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-950/40 text-amber-400 border border-amber-900/30">Intéressé</span>
                        <% } else if (reg.status === 'en_attente') { %>
                          <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-orange-950/40 text-orange-400 border border-orange-900/30">En Attente</span>
                        <% } else if (reg.status === 'pas_interesse') { %>
                          <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-rose-950/40 text-rose-400 border border-rose-900/30">Pas Intéressé</span>
                        <% } else { %>
                          <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-950/40 text-blue-400 border border-blue-900/30">Désinscrit</span>
                        <% } %>
                      </td>
                      <td class="px-6 py-4 text-xs text-slate-500">
                        <%= new Date(reg.updated_at).toLocaleString('fr-FR') %>
                      </td>
                      <td class="px-6 py-4 text-xs text-right">
                        <% if (reg.status === 'inscrit' || reg.status === 'interesse') { %>
                          <form action="/events/<%= event.id %>/registrations/<%= reg.user_id %>/waitlist" method="POST" class="inline">
                            <button type="submit" class="px-2.5 py-1 rounded-lg bg-orange-600/20 text-orange-400 border border-orange-600/30 hover:bg-orange-600 hover:text-white transition duration-200 text-[11px] font-semibold shadow-sm">
                              🟠 Mettre en attente
                            </button>
                          </form>
                        <% } else if (reg.status === 'en_attente') { %>
                          <form action="/events/<%= event.id %>/registrations/<%= reg.user_id %>/waitlist" method="POST" class="inline">
                            <button type="submit" class="px-2.5 py-1 rounded-lg bg-emerald-600/20 text-emerald-400 border border-emerald-600/30 hover:bg-emerald-600 hover:text-white transition duration-200 text-[11px] font-semibold shadow-sm">
                              🟢 Réintégrer
                            </button>
                          </form>
                        <% } else { %>
                          <span class="text-slate-600 italic">-</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- Formulaire d'Ajout Manuel -->
          <div class="px-6 py-5 border-t border-slate-800 bg-slate-900/40">
            <h4 class="font-bold text-white text-sm mb-3">➕ Ajouter un participant manuellement</h4>
            <form action="/events/<%= event.id %>/registrations/add" method="POST" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              <input type="text" name="user_id" placeholder="ID Utilisateur Discord (ex: 123456789...)" required class="px-3 py-2 rounded-xl bg-slate-950 border border-slate-850 text-slate-200 placeholder-slate-600 focus:outline-none focus:border-discord text-xs font-mono">
              <input type="text" name="username" placeholder="Pseudo (ex: JeanDupont)" required class="px-3 py-2 rounded-xl bg-slate-950 border border-slate-850 text-slate-200 placeholder-slate-600 focus:outline-none focus:border-discord text-xs">
              <button type="submit" class="px-4 py-2 rounded-xl bg-discord hover:bg-discord/90 text-white font-semibold text-xs transition duration-200 shadow-md shadow-discord/20">
                Ajouter le participant
              </button>
            </form>
          </div>
        </div>
      </div>
    </div> <!-- Closes grid-cols-2 layout -->
  </main>

  <!-- Footer -->
  <footer class="border-t border-slate-900 bg-slate-950 py-6 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between text-xs text-slate-500">
      <span>© 2026 EventBot. Tous droits réservés.</span>
      <span>Propulsé par Antigravity & Node.js</span>
    </div>
  </footer>

</body>
</html>
