<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event ? event.title : 'Inscription' %> — EventBot Portal</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            discord: '#5865F2',
            discordDark: '#36393f',
            discordBackground: '#2f3136'
          }
        }
      }
    }
  </script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');
    body {
      font-family: 'Outfit', sans-serif;
    }
  </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen flex items-center justify-center p-4 selection:bg-discord selection:text-white">

  <div class="w-full max-w-md bg-slate-900/50 backdrop-blur-xl border border-slate-800 p-8 rounded-3xl shadow-2xl relative overflow-hidden">
    <div class="absolute -top-10 -right-10 w-40 h-40 bg-discord/10 rounded-full filter blur-3xl"></div>
    <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-discord/10 rounded-full filter blur-3xl"></div>

    <% if (!event) { %>
      <div class="text-center relative">
        <h2 class="text-2xl font-bold tracking-tight text-white mb-2">Événement introuvable</h2>
        <p class="text-slate-400 text-sm">Ce lien d'inscription n'est plus valide.</p>
      </div>

    <% } else if (success) { %>
      <div class="text-center relative">
        <div class="inline-flex bg-emerald-500 p-3 rounded-2xl text-white shadow-xl shadow-emerald-500/30 mb-4">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold tracking-tight text-white mb-2">Inscription confirmée !</h2>
        <p class="text-slate-400 text-sm">Vous êtes bien inscrit(e) à <strong class="text-white"><%= event.title %></strong>. À bientôt !</p>
      </div>

    <% } else if (isBlocked) { %>
      <div class="text-center relative">
        <h2 class="text-2xl font-bold tracking-tight text-white mb-2">🔒 Inscriptions fermées</h2>
        <p class="text-slate-400 text-sm">Les inscriptions pour <strong class="text-white"><%= event.title %></strong> sont actuellement fermées.</p>
      </div>

    <% } else { %>
      <div class="text-center mb-8 relative">
        <div class="inline-flex bg-discord p-3 rounded-2xl text-white shadow-xl shadow-discord/30 mb-4">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold tracking-tight text-white"><%= event.title %></h2>
        <p class="text-slate-400 text-sm mt-1"><%= event.desc_short %></p>
      </div>

      <% if (error) { %>
        <div class="mb-6 p-4 rounded-xl bg-rose-500/10 border border-rose-500/20 text-rose-450 text-sm">
          <%= error %>
        </div>
      <% } %>

      <form action="/register/<%= event.id %>" method="POST" class="space-y-6 relative">
        <div>
          <label for="discord_handle" class="block text-sm font-semibold text-slate-350 mb-2">Pseudo Discord</label>
          <input type="text" id="discord_handle" name="discord_handle" required placeholder="votre_pseudo_discord"
            class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-white placeholder-slate-600 focus:outline-none focus:border-discord transition duration-200">
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-slate-350 mb-2">Email (optionnel)</label>
          <input type="email" id="email" name="email" placeholder="vous@exemple.com"
            class="w-full px-4 py-3 rounded-xl bg-slate-950 border border-slate-800 text-white placeholder-slate-600 focus:outline-none focus:border-discord transition duration-200">
        </div>

        <button type="submit"
          class="w-full py-3.5 px-4 rounded-xl bg-discord hover:bg-discord/90 text-white font-semibold shadow-lg shadow-discord/20 transition-all duration-200 transform hover:-translate-y-0.5">
          S'inscrire
        </button>
      </form>
    <% } %>
  </div>

</body>
</html>
