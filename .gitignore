# Dependencies
node_modules/
/jspm_packages/
.pnp
.pnp.js

# Environment secrets and local configurations (CRITICAL to prevent leaks)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example.local
*.env

# SQLite local databases and data storage
/data/
*.db
*.sqlite
*.sqlite3

# Uploaded media and documents (avoids commit of user-uploaded files)
/public/uploads/*
!/public/uploads/.gitkeep

# Logs and debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Diagnostic reports (Next.js / Node.js)
.pnpm-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# OS and Editor configurations
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Testing coverage reports
/coverage/
.nyc_output
